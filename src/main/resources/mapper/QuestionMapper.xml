<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.dailw.mapper.QuestionMapper">

    <resultMap id="BaseResultMap" type="com.dailw.model.entity.Question">
            <id property="id" column="id" jdbcType="BIGINT"/>
            <result property="title" column="title" jdbcType="VARCHAR"/>
            <result property="content" column="content" jdbcType="VARCHAR"/>
            <result property="tags" column="tags" jdbcType="VARCHAR"/>
            <result property="answer" column="answer" jdbcType="VARCHAR"/>
            <result property="submitNum" column="submit_num" jdbcType="INTEGER"/>
            <result property="acceptedNum" column="accepted_num" jdbcType="INTEGER"/>
            <result property="judgeCase" column="judge_case" jdbcType="VARCHAR"/>
            <result property="judgeConfig" column="judge_config" jdbcType="VARCHAR"/>
            <result property="thumbNum" column="thumb_num" jdbcType="INTEGER"/>
            <result property="favourNum" column="favour_num" jdbcType="INTEGER"/>
            <result property="difficulty" column="difficulty" jdbcType="VARCHAR"/>
            <result property="userId" column="user_id" jdbcType="BIGINT"/>
            <result property="createTime" column="create_time" jdbcType="TIMESTAMP"/>
            <result property="updateTime" column="update_time" jdbcType="TIMESTAMP"/>
            <result property="deleted" column="deleted" jdbcType="TINYINT"/>
    </resultMap>

    <sql id="Base_Column_List">
        id,title,content,
        tags,answer,submit_num,
        accepted_num,judge_case,judge_config,
        thumb_num,favour_num,difficulty,
        user_id,create_time,update_time,
        deleted
    </sql>

    <select id="selectQuestionInfo" resultType="com.dailw.model.vo.QuestionInfoVO">
        SELECT
            COUNT(*) AS total,
            SUM(CASE WHEN difficulty = 'easy' OR difficulty = '简单' THEN 1 ELSE 0 END) AS easyCount,
            SUM(CASE WHEN difficulty = 'medium' OR difficulty = '中等' THEN 1 ELSE 0 END) AS mediumCount,
            SUM(CASE WHEN difficulty = 'hard' OR difficulty = '困难' THEN 1 ELSE 0 END) AS hardCount,
            COALESCE(SUM(submit_num), 0) AS submitCount,
            COALESCE(SUM(accepted_num), 0) AS acceptedCount,
            -- 直接在 SQL 中计算通过率（避免 Java 端计算）
            CASE
                WHEN SUM(submit_num) > 0 THEN ROUND((SUM(accepted_num) / SUM(submit_num)) * 100, 2)
                ELSE 0
                END AS passRate
        FROM question
        WHERE deleted = 0;
    </select>

</mapper>
